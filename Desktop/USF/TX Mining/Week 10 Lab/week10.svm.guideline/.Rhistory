)
svmOutput
# Write your code below.
rmse_value <- RMSE(predicted, actual)
# Write your code below.
predicted <- predict(svmOutput, testData)
actual <- testData$Ozone
rmse <- sqrt(mean((actual-predicted)^2))
rmse
# Write your code below.
testData$error <- abs(actual-predicted)
