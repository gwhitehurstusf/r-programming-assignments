# Add your library below.
library(ggplot2)
library(readxl)
# No code necessary; Just review the data.
# Write your code below.
myDF<-as.data.frame(readxl::read_excel("./data/mlr01.xls"))
colnames(myDF) <- c("nFawn", "adultPop", "precip", "winter")
head(myDF)
# Write your code below.
str(myDF)
# Write your code below.
install.packages("dplyr")
library(dplyr)
ggplot(myDF, aes(x=adultPop, y=nFawn)) +
geom_point() +
stat_smooth(method = "lm", col="white", fill="brown") +
labs(title = "Fawn Count by Adult Population",
x = "Adult Population",
y = "Fawn Count") +
theme_minimal()
# Write your code below.
ggplot(myDF, aes(x=precip, y=nFawn)) +
geom_point() +
stat_smooth(method = "lm", col="tan", fill="lightgreen") +
labs(title = "Fawn Count by Annual Precipitation",
x = "Annual Precipitation",
y = "Fawn Count") +
theme_minimal()
# Write your code below.
ggplot(myDF, aes(x=winter, y=nFawn)) +
geom_point() +
stat_smooth(method = "lm", col="tan", fill="lightblue") +
labs(title = "Fawn Count by Winter Severity Index",
x = "Winter Severity Index",
y = "Fawn Count") +
theme_minimal()
# Write your code below.
first_M <- lm(formula = nFawn ~ precip, data = myDF)
summary(first_M)
# Write your code below.
second_M <- lm(formula = nFawn ~ precip + adultPop, data = myDF)
summary(second_M)
# Write your code below.
third_M <- lm(formula = nFawn ~ precip + adultPop + winter, data = myDF)
summary(third_M)
