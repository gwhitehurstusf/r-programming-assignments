library(arules)
# Write your code below.
install.packages("arules")
library(arules)
rules <- apriori(t,
parameter = list(supp = 0.005, conf = 0.5),
appearance = list(rhs = c("Survived=Yes")))
inspect(sort(rules, by = "lift")[1:3])
inspect(sort(rules, by = "lift")[1:10])
